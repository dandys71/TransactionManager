Content-Type: application/json

{
  "fromAccountId": "MUJ-HLAVNI-UCET",
  "toAccountId": "MUJ-SPORICI-UCET",
  "amount": 2000,
  "currency": "CZK",
  "note": "Převod na spoření"
}

